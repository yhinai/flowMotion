# Google AI (Gemini + Veo + Nano Banan Pro)
# Get your API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ElevenLabs (TTS Narration + Sound Effects)
# Get your API key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Vertex AI (for Lyria 2)
# Your GCP project ID from https://console.cloud.google.com
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us-central1

# Nexla / Express (live data pipelines → autonomous video topics)
# Sign up at dataops.nexla.io, create flows, then paste IDs here
NEXLA_API_KEY=
NEXLA_NEWS_NEXSET_ID=
NEXLA_CRYPTO_NEXSET_ID=
NEXLA_WEATHER_NEXSET_ID=

# Optional: NewsAPI key for direct fallback (newsapi.org)
NEWSAPI_KEY=

# DigitalOcean Spaces (primary video storage + CDN)
# Create a Space at https://cloud.digitalocean.com/spaces
# Generate Spaces access keys at https://cloud.digitalocean.com/account/api/spaces
DO_SPACES_KEY=           # Spaces access key ID
DO_SPACES_SECRET=        # Spaces secret access key
DO_SPACES_BUCKET=flowmotion-videos   # Name of the Space you created
DO_SPACES_REGION=nyc3               # Region slug (e.g. nyc3, sfo3, ams3)

# Supabase (Storage — fallback when DO Spaces not configured)
# Get these from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=video-assets

# Telegram Bot (optional)
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Redis (optional - for BullMQ persistent queue + bot state)
REDIS_URL=redis://localhost:6379
ENABLE_BULLMQ=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google AI (Gemini + Veo + Nano Banan Pro)
GEMINI_API_KEY=

# ElevenLabs (TTS Narration + Sound Effects)
ELEVENLABS_API_KEY=

# Vertex AI (for Lyria 2)
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us-central1

# Nexla / Express (live data pipelines → autonomous video topics)
# Sign up at dataops.nexla.io, create flows, then paste IDs here
NEXLA_API_KEY=
NEXLA_NEWS_NEXSET_ID=
NEXLA_CRYPTO_NEXSET_ID=
NEXLA_WEATHER_NEXSET_ID=

# Optional: NewsAPI key for direct fallback (newsapi.org)
NEWSAPI_KEY=

# DigitalOcean Spaces (primary video storage + CDN)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=flowmotion-videos
DO_SPACES_REGION=nyc3

# Supabase (Storage — fallback when DO Spaces not configured)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=video-assets

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=

# Redis (optional - for BullMQ persistent queue + bot state)
REDIS_URL=redis://localhost:6379
ENABLE_BULLMQ=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

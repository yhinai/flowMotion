# Google AI (Gemini + Veo + Nano Banan Pro)
GEMINI_API_KEY=

# ElevenLabs (TTS Narration + Sound Effects)
ELEVENLABS_API_KEY=

# Vertex AI (for Lyria 2)
GOOGLE_CLOUD_PROJECT_ID=
